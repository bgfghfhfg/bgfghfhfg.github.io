            }, 100);
        }

        function createProxyCard(url, index) {
            const card = document.createElement('div');
            card.className = 'proxy-card';
            if (isProxyPinned(url, currentTab)) {
                card.classList.add('pinned');
            }
            card.style.animationDelay = `${index * 0.1}s`;

            if (isProxyPinned(url, currentTab)) {
                const pinIndicator = document.createElement('i');
                pinIndicator.className = 'fas fa-thumbtack pin-indicator';
                card.appendChild(pinIndicator);
            }

            const urlText = document.createElement('p');
            urlText.className = 'mb-4 proxy-url';
            urlText.textContent = url;

            const ellipsisIcon = document.createElement('i');
            ellipsisIcon.className = 'fas fa-ellipsis-h menu-icon';
            ellipsisIcon.style.display = 'flex';
            ellipsisIcon.style.alignItems = 'center';
            ellipsisIcon.style.justifyContent = 'center';

            const dropdownMenu = document.createElement('div');
            dropdownMenu.className = 'dropdown-menu';

            const pinOption = document.createElement('button');
            pinOption.onclick = (e) => {
                e.stopPropagation();
                const isPinned = isProxyPinned(url, currentTab);
                if (isPinned) {
                    unpinProxy(url, currentTab, card);
                } else {
                    pinProxy(url, currentTab, card);
                }
                setTimeout(() => {
                    dropdownMenu.classList.remove('show');
                    ellipsisIcon.classList.remove('active');
                    activeDropdown = null;
                }, 300);
            };

            if (isProxyPinned(url, currentTab)) {
                pinOption.innerHTML = advancedMode ? '<i class="fas fa-thumbtack fa-rotate-90"></i> Unpin Game' : '<i class="fas fa-thumbtack fa-rotate-90"></i> Unpin proxy';
            } else {
                pinOption.innerHTML = advancedMode ? '<i class="fas fa-thumbtack"></i> Pin Game' : '<i class="fas fa-thumbtack"></i> Pin proxy';
            }
            
            dropdownMenu.appendChild(pinOption);
            card.appendChild(ellipsisIcon);
            card.appendChild(dropdownMenu);

            ellipsisIcon.onclick = (e) => {
                e.stopPropagation();
                const wasActive = ellipsisIcon.classList.contains('active');
                
                if (activeDropdown && activeDropdown !== dropdownMenu) {
                    activeDropdown.classList.remove('show');
                    activeDropdown.previousElementSibling.classList.remove('active');
                }

                ellipsisIcon.classList.toggle('active');
                dropdownMenu.classList.toggle('show');
                
                if (!wasActive) {
                    activeDropdown = dropdownMenu;
                } else {
                    activeDropdown = null;
                }
            };

            const buttonContainer = document.createElement('div');
            buttonContainer.className = 'button-container';

            const openBtn = document.createElement('button');
            openBtn.className = 'open-button';
            openBtn.textContent = 'Open';
            openBtn.onclick = () => openProxy(url);

            buttonContainer.appendChild(openBtn);
            card.appendChild(urlText);
            card.appendChild(buttonContainer);

            return card;
        }

        document.addEventListener('selectionchange', handleSelection);

        document.addEventListener('click', (e) => {
            if (activeDropdown && !e.target.closest('.proxy-card')) {
                activeDropdown.classList.remove('show');
                activeDropdown.previousElementSibling.classList.remove('active');
                activeDropdown = null;
            }
        });

        async function switchTab(group) {
            currentTab = group;
            showLoading();

            if (!proxyQueue[currentTab] || proxyQueue[currentTab].length === 0) {
                proxyQueue[currentTab] = shuffle([...proxyGroups[currentTab]]);
            }

            document.querySelectorAll('.tab-button').forEach(button => {
                button.classList.toggle('active', button.textContent === group);
            });

            await new Promise(resolve => setTimeout(resolve, 300));

            const content = document.getElementById('proxyContent');
            content.innerHTML = '';

            cleanupInvalidPins(group, proxyGroups[group]);

            content.appendChild(createRandomProxyCard(proxyGroups[group]));

            originalProxyOrder[group].forEach((url, index) => {
                if (isProxyPinned(url, group)) {
                    content.insertBefore(createProxyCard(url, index), content.children[1]);
                } else {
                    content.appendChild(createProxyCard(url, index));
                }
            });

            hideLoading();
        }

